{
    "//": "Machine-specific Efinity tool paths. Generated on project creation from",
    "//1": "the extension settings; edit the 'machine' preset to update them.",
    "version": 6,
    "configurePresets": [
        {
            "name": "machine",
            "hidden": true,
            "cacheVariables": {
                "OPENOCD": "__OPENOCD_PATH__",
                "TOOLCHAIN_DIR": "__TOOLCHAIN_PATH__",
                "EFINITY_INSTALL_DIR": "__EFINITY_PATH__"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "inherits": [
                "debug-base",
                "machine"
            ]
        },
        {
            "name": "release",
            "displayName": "Release",
            "inherits": [
                "release-base",
                "machine"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        }
    ]
}
