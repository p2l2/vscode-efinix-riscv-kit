{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Unix Makefiles",
            "toolchainFile": "${sourceDir}/cmake/riscv-efinix.cmake",
            "cacheVariables": {
                "RISCV_ISA": "rv32imafdc",
                "RISCV_ABI": "ilp32d",
                "SMP": true,
                "EFX_BSP":  "__BSP_DIR__"
            }
        },
        {
            "name": "debug-base",
            "hidden": true,
            "inherits": "base",
            "binaryDir": "${sourceDir}/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release-base",
            "hidden": true,
            "inherits": "base",
            "binaryDir": "${sourceDir}/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        }
    ]
}

